generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Multi-Tenant ──────────────────────────────────────────

model Tenant {
  id        String    @id @default(uuid()) @db.Uuid
  slug      String    @unique @db.VarChar(100)
  name      String    @db.VarChar(200)
  plan      String    @default("basic") @db.VarChar(50)
  locale    String    @default("pt-PT") @db.VarChar(10)
  timezone  String    @default("Europe/Lisbon") @db.VarChar(50)
  settings              Json      @default("{}")
  logoUrl               String?   @map("logo_url") @db.VarChar(500)
  onboardingCompletedAt DateTime? @map("onboarding_completed_at") @db.Timestamptz
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  users                User[]
  projects             Project[]
  people               Person[]
  tasks                Task[]
  areas                Area[]
  objectives           Objective[]
  keyResults           KeyResult[]
  okrSnapshots         OkrSnapshot[]
  projectPhases        ProjectPhase[]
  clients              Client[]
  clientContacts       ClientContact[]
  interactions         Interaction[]
  alerts               Alert[]
  contentItems         ContentItem[]
  trustScores          TrustScore[]
  maestroActions       MaestroAction[]
  maestroConversations MaestroConversation[]
  maestroMessages      MaestroMessage[]
  syncLogs             SyncLog[]
  workflowTemplates    WorkflowTemplate[]
  workflowSteps        WorkflowTemplateStep[]
  workflowInstances    WorkflowInstance[]
  workflowTasks        WorkflowInstanceTask[]
  githubRepos          GithubRepo[]
  githubEvents         GithubEvent[]
  devMetrics           DevMetricsDaily[]
  feedbackSessions     FeedbackSession[]
  feedbackItems        FeedbackItem[]
  userProjectAccess    UserProjectAccess[]
  moduleConfigs        TenantModuleConfig[]
  opportunities          Opportunity[]
  opportunityActivities  OpportunityActivity[]
  timeEntries            TimeEntry[]
  emailRecords           EmailRecord[]
  investmentMaps         InvestmentMap[]
  investmentRubrics      InvestmentRubric[]
  emailCampaigns         EmailCampaign[]
  emailTemplates         EmailTemplate[]
  campaignRecipients     CampaignRecipient[]
  llmConfig              TenantLLMConfig?

  @@map("tenants")
}

model TenantLLMConfig {
  id               String  @id @default(uuid()) @db.Uuid
  tenantId         String  @unique @map("tenant_id") @db.Uuid
  provider         String  @default("minimax") @db.VarChar(50)
  endpoint         String? @db.VarChar(500)
  model            String  @default("default") @db.VarChar(200)
  apiKeyEncrypted  String? @map("api_key_encrypted") @db.Text
  maxTokens        Int     @default(4096) @map("max_tokens")
  temperature      Float   @default(0.7)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("tenant_llm_config")
}

model ModuleCatalog {
  id        String  @id @default(uuid()) @db.Uuid
  key       String  @unique @db.VarChar(50)
  label     Json
  icon      String  @db.VarChar(50)
  route     String  @db.VarChar(100)
  sortOrder Int     @default(0) @map("sort_order")
  isCore    Boolean @default(false) @map("is_core")
  // Tier 1: sempre activo (core). 2: activo por defeito. 3: opcional. 4: experimental.
  tier      Int     @default(3)

  tenantConfigs    TenantModuleConfig[]
  userModuleAccess UserModuleAccess[]

  @@map("module_catalog")
}

model TenantModuleConfig {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  moduleKey String  @map("module_key") @db.VarChar(50)
  isEnabled Boolean @default(true) @map("is_enabled")
  config    Json    @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  module ModuleCatalog @relation(fields: [moduleKey], references: [key])

  @@unique([tenantId, moduleKey])
  @@map("tenant_module_config")
}

model UserModuleAccess {
  id        String  @id @default(uuid()) @db.Uuid
  userId    String  @map("user_id") @db.Uuid
  moduleKey String  @map("module_key") @db.VarChar(50)
  canRead   Boolean @default(true) @map("can_read")
  canWrite  Boolean @default(false) @map("can_write")

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  module ModuleCatalog @relation(fields: [moduleKey], references: [key], onDelete: Cascade)

  @@unique([userId, moduleKey])
  @@map("user_module_access")
}

// ─── Auth ───────────────────────────────────────────────────

enum Role {
  admin
  manager
  membro
  cliente
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  email        String   @db.VarChar(300)
  passwordHash String   @map("password_hash") @db.Text
  role         Role     @default(membro)
  isActive     Boolean  @default(true) @map("is_active")
  personId           String   @unique @map("person_id") @db.Uuid
  telegramChatId     String?  @map("telegram_chat_id") @db.VarChar(50)
  whatsappPhoneId    String?  @map("whatsapp_phone_id") @db.VarChar(20)
  notificationPrefs  Json     @default("{}") @map("notification_prefs")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  person             Person              @relation(fields: [personId], references: [id])
  projectAssignments UserProjectAccess[]
  moduleAccess       UserModuleAccess[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model UserProjectAccess {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([tenantId])
  @@map("user_project_access")
}

// ─── Projects ───────────────────────────────────────────────

model Project {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name        String    @db.VarChar(200)
  slug        String    @db.VarChar(100)
  type        String    @db.VarChar(50)
  status      String    @default("ativo") @db.VarChar(50)
  health      String    @default("green") @db.VarChar(20)
  progress    Int       @default(0)
  description String?   @db.Text
  color       String?   @db.VarChar(7)
  archivedAt  DateTime? @map("archived_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  phases           ProjectPhase[]
  objectives       Objective[]
  tasks            Task[]
  client           Client?
  interactions     Interaction[]
  alerts           Alert[]            @relation("AlertProject")
  contentItems     ContentItem[]
  workflowTemplates  WorkflowTemplate[]
  workflowInstances  WorkflowInstance[]
  githubRepos        GithubRepo[]
  userAccess         UserProjectAccess[]
  feedbackSessions   FeedbackSession[]
  timeEntries    TimeEntry[] @relation("TimeEntryProject")
  emailRecords   EmailRecord[]
  investmentMap  InvestmentMap?

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("projects")
}

model ProjectPhase {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  name        String    @db.VarChar(200)
  description String?   @db.Text
  phaseOrder  Int       @map("phase_order")
  status      String    @default("pendente") @db.VarChar(50)
  progress    Int       @default(0)
  startDate   DateTime? @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  project Project @relation(fields: [projectId], references: [id])
  tasks   Task[]

  @@index([tenantId])
  @@map("project_phases")
}

// ─── Objectives ─────────────────────────────────────────────

model Objective {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  title        String    @db.VarChar(300)
  description  String?   @db.Text
  targetValue  Decimal?  @map("target_value")
  currentValue Decimal   @default(0) @map("current_value")
  unit         String?   @db.VarChar(50)
  deadline     DateTime? @db.Date
  projectId    String?   @map("project_id") @db.Uuid
  status       String    @default("ativo") @db.VarChar(50)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  project    Project?     @relation(fields: [projectId], references: [id])
  keyResults KeyResult[]

  @@index([tenantId])
  @@map("objectives")
}

model KeyResult {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  objectiveId  String    @map("objective_id") @db.Uuid
  title        String    @db.VarChar(300)
  targetValue  Decimal?  @map("target_value")
  currentValue Decimal   @default(0) @map("current_value")
  unit         String?   @db.VarChar(50)
  weight       Int       @default(1)
  deadline     DateTime? @db.Date
  status       String    @default("ativo") @db.VarChar(50)
  krOrder      Int       @default(0) @map("kr_order")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  objective Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([tenantId])
  @@index([objectiveId], map: "idx_key_results_objective")
  @@map("key_results")
}

// ─── People ─────────────────────────────────────────────────

model Person {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name           String    @db.VarChar(200)
  email          String?   @db.VarChar(300)
  role           String?   @db.VarChar(200)
  type           String    @db.VarChar(50)
  avatarColor    String?   @map("avatar_color") @db.VarChar(7)
  githubUsername String?   @map("github_username") @db.VarChar(100)
  costPerHour    Decimal?  @map("cost_per_hour") @db.Decimal(8, 2)
  weeklyHours    Float?    @default(40) @map("weekly_hours")
  archivedAt     DateTime? @map("archived_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  tasks                    Task[]
  validatedTasks           Task[]                 @relation("TaskValidator")
  feedbackItemsReviewed    FeedbackItem[]         @relation("FeedbackReviewer")
  feedbackItemsTriaged     FeedbackItem[]         @relation("FeedbackTriager")
  feedbackSessions         FeedbackSession[]      @relation("FeedbackTester")
  clientContacts           ClientContact[]
  contentApproved          ContentItem[]
  user                     User?
  areasOwned               Area[]                 @relation("AreaOwner")
  workflowTemplatesCreated WorkflowTemplate[]     @relation("WorkflowCreator")
  workflowDefaultAssignee  WorkflowTemplateStep[] @relation("StepDefaultAssignee")
  workflowInstancesStarted WorkflowInstance[]     @relation("WorkflowStarter")
  githubEvents             GithubEvent[]          @relation("EventAuthor")
  maestroActionsPerformed  MaestroAction[]        @relation("MaestroActionPerformedBy")
  maestroConversations     MaestroConversation[]  @relation("MaestroConversationOwner")
  opportunitiesAsContact  Opportunity[]         @relation("OpportunityContact")
  opportunitiesOwned      Opportunity[]         @relation("OpportunityOwner")
  activitiesCreated       OpportunityActivity[] @relation("ActivityCreator")
  timeEntries             TimeEntry[]           @relation("TimeEntryPerson")
  timeEntriesApproved     TimeEntry[]           @relation("TimeEntryApprover")
  emailRecords            EmailRecord[]         @relation("EmailPerson")
  campaignsCreated        EmailCampaign[]       @relation("CampaignCreator")
  campaignRecipients      CampaignRecipient[]   @relation("CampaignRecipientPerson")

  @@index([tenantId])
  @@index([archivedAt], map: "idx_people_archived")
  @@map("people")
}

// ─── Tasks ──────────────────────────────────────────────────

model Task {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  title       String    @db.VarChar(500)
  description String?   @db.Text
  projectId   String?   @map("project_id") @db.Uuid
  areaId      String?   @map("area_id") @db.Uuid
  phaseId     String?   @map("phase_id") @db.Uuid
  assigneeId  String?   @map("assignee_id") @db.Uuid
  status      String    @default("backlog") @db.VarChar(50)
  priority    String    @default("media") @db.VarChar(20)
  origin      String?   @db.VarChar(100)
  originDate  DateTime? @map("origin_date") @db.Date
  originRef   String?   @map("origin_ref") @db.Text
  deadline    DateTime? @db.Date
  completedAt DateTime? @map("completed_at") @db.Timestamptz
  daysStale   Int       @default(0) @map("days_stale")
  kanbanOrder Int       @default(0) @map("kanban_order")
  archivedAt  DateTime? @map("archived_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // AI / Trust Score
  aiExtracted      Boolean   @default(false) @map("ai_extracted")
  aiConfidence     Decimal?  @map("ai_confidence")
  validationStatus String    @default("confirmed") @map("validation_status") @db.VarChar(20)
  validatedById    String?   @map("validated_by") @db.Uuid
  validatedAt      DateTime? @map("validated_at") @db.Timestamptz
  originalData     Json?     @map("original_data")

  // OKR
  keyResultId        String?   @map("key_result_id") @db.Uuid

  estimatedHours Float?    @map("estimated_hours")

  // GitHub
  githubBranch       String?   @map("github_branch") @db.VarChar(300)
  githubPrNumber     Int?      @map("github_pr_number")
  githubPrStatus     String?   @map("github_pr_status") @db.VarChar(50)
  githubPrUrl        String?   @map("github_pr_url") @db.Text
  githubLastCommitAt DateTime? @map("github_last_commit_at") @db.Timestamptz
  devStatus          String    @default("sem_codigo") @map("dev_status") @db.VarChar(50)

  // Handoff para produtor externo (Bruno etc.)
  handoffStatus     String?   @map("handoff_status") @db.VarChar(20)
  handoffAgentId    String?   @map("handoff_agent_id") @db.VarChar(100)
  handoffSentAt     DateTime? @map("handoff_sent_at") @db.Timestamptz
  handoffClaimedAt  DateTime? @map("handoff_claimed_at") @db.Timestamptz
  handoffResolvedAt DateTime? @map("handoff_resolved_at") @db.Timestamptz
  handoffResolution Json?     @map("handoff_resolution")

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  project   Project?      @relation(fields: [projectId], references: [id])
  area      Area?         @relation(fields: [areaId], references: [id])
  phase     ProjectPhase? @relation(fields: [phaseId], references: [id])
  assignee  Person?       @relation(fields: [assigneeId], references: [id])
  validator Person?       @relation("TaskValidator", fields: [validatedById], references: [id])
  keyResult KeyResult?    @relation(fields: [keyResultId], references: [id], onDelete: SetNull)
  alerts    Alert[]       @relation("AlertTask")

  workflowInstanceTasks WorkflowInstanceTask[]
  githubEvents          GithubEvent[]
  feedbackItem          FeedbackItem?            @relation("FeedbackTask")
  timeEntries   TimeEntry[] @relation("TimeEntryTask")

  @@index([tenantId])
  @@index([projectId], map: "idx_tasks_project")
  @@index([assigneeId], map: "idx_tasks_assignee")
  @@index([status], map: "idx_tasks_status")
  @@index([priority], map: "idx_tasks_priority")
  @@index([archivedAt], map: "idx_tasks_archived")
  @@index([projectId, status, kanbanOrder], map: "idx_tasks_kanban")
  @@index([handoffStatus, handoffAgentId], map: "idx_tasks_handoff")
  @@map("tasks")
}

// ─── Clients ────────────────────────────────────────────────

model Client {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  companyName       String    @map("company_name") @db.VarChar(300)
  projectId         String    @unique @map("project_id") @db.Uuid
  status            String    @default("ativo") @db.VarChar(50)
  lastInteractionAt DateTime? @map("last_interaction_at") @db.Timestamptz
  daysSinceContact  Int       @default(0) @map("days_since_contact")
  notes             String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  project      Project         @relation(fields: [projectId], references: [id])
  contacts     ClientContact[]
  interactions Interaction[]   @relation("InteractionClient")
  alerts       Alert[]         @relation("AlertClient")
  emailRecords EmailRecord[]   @relation("EmailClient")

  @@index([tenantId])
  @@map("clients")
}

model ClientContact {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  personId  String   @map("person_id") @db.Uuid
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  client Client @relation(fields: [clientId], references: [id])
  person Person @relation(fields: [personId], references: [id])

  @@index([tenantId])
  @@map("client_contacts")
}

// ─── Interactions (Client Hub Feed) ─────────────────────────

model Interaction {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  projectId       String?  @map("project_id") @db.Uuid
  clientId        String?  @map("client_id") @db.Uuid
  type            String   @db.VarChar(50)
  title           String   @db.VarChar(500)
  body            String?  @db.Text
  source          String?  @db.VarChar(100)
  sourceRef       String?  @map("source_ref") @db.Text
  participants    String[] @db.Uuid
  interactionDate DateTime @map("interaction_date") @db.Timestamptz
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  // AI / Trust Score
  aiExtracted      Boolean   @default(false) @map("ai_extracted")
  aiConfidence     Decimal?  @map("ai_confidence")
  validationStatus String    @default("confirmed") @map("validation_status") @db.VarChar(20)
  validatedById    String?   @map("validated_by") @db.Uuid
  validatedAt      DateTime? @map("validated_at") @db.Timestamptz
  originalData     Json?     @map("original_data")

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
  client  Client?  @relation("InteractionClient", fields: [clientId], references: [id])
  emailRecord EmailRecord?

  @@index([tenantId])
  @@index([projectId], map: "idx_interactions_project")
  @@index([clientId], map: "idx_interactions_client")
  @@index([interactionDate(sort: Desc)], map: "idx_interactions_date")
  @@map("interactions")
}

// ─── Alerts ─────────────────────────────────────────────────

model Alert {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  type             String   @db.VarChar(50)
  severity         String   @default("warning") @db.VarChar(20)
  title            String   @db.VarChar(500)
  description      String?  @db.Text
  relatedTaskId    String?  @map("related_task_id") @db.Uuid
  relatedProjectId String?  @map("related_project_id") @db.Uuid
  relatedClientId  String?  @map("related_client_id") @db.Uuid
  isDismissed      Boolean  @default(false) @map("is_dismissed")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  task    Task?    @relation("AlertTask", fields: [relatedTaskId], references: [id])
  project Project? @relation("AlertProject", fields: [relatedProjectId], references: [id])
  client  Client?  @relation("AlertClient", fields: [relatedClientId], references: [id])

  @@index([tenantId])
  @@index([isDismissed], map: "idx_alerts_dismissed")
  @@map("alerts")
}

// ─── Content Pipeline ───────────────────────────────────────

model ContentItem {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  title          String    @db.VarChar(500)
  format         String?   @db.VarChar(50)
  status         String    @default("proposta") @db.VarChar(50)
  sourceCallDate DateTime? @map("source_call_date") @db.Date
  sourceCallRef  String?   @map("source_call_ref") @db.Text
  scriptPath     String?   @map("script_path") @db.Text
  videoPath      String?   @map("video_path") @db.Text
  platform       String?   @db.VarChar(100)
  approvedById   String?   @map("approved_by") @db.Uuid
  approvedAt     DateTime? @map("approved_at") @db.Timestamptz
  publishedAt    DateTime? @map("published_at") @db.Timestamptz
  projectId      String?   @map("project_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // AI / Trust Score
  aiExtracted      Boolean   @default(false) @map("ai_extracted")
  aiConfidence     Decimal?  @map("ai_confidence")
  validationStatus String    @default("confirmed") @map("validation_status") @db.VarChar(20)
  validatedById    String?   @map("validated_by") @db.Uuid
  validatedAt      DateTime? @map("validated_at") @db.Timestamptz
  originalData     Json?     @map("original_data")

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  approvedBy Person?  @relation(fields: [approvedById], references: [id])
  project    Project? @relation(fields: [projectId], references: [id])

  @@index([tenantId])
  @@index([status], map: "idx_content_status")
  @@map("content_items")
}

// ─── Trust Scores ───────────────────────────────────────────

model TrustScore {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  agentId            String    @default("maestro-internal") @map("agent_id") @db.VarChar(100)
  extractionType     String    @map("extraction_type") @db.VarChar(100)
  score              Int       @default(0)
  totalConfirmations Int       @default(0) @map("total_confirmations")
  totalEdits         Int       @default(0) @map("total_edits")
  totalRejections    Int       @default(0) @map("total_rejections")
  lastInteractionAt  DateTime? @map("last_interaction_at") @db.Timestamptz
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
