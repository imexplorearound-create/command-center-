  task       Task?    @relation("TimeEntryTask", fields: [taskId], references: [id])
  project    Project? @relation("TimeEntryProject", fields: [projectId], references: [id])
  area       Area?    @relation("TimeEntryArea", fields: [areaId], references: [id])
  approvedBy Person?  @relation("TimeEntryApprover", fields: [approvedById], references: [id])

  @@index([tenantId])
  @@index([personId, date], map: "idx_time_entries_person_date")
  @@index([projectId], map: "idx_time_entries_project")
  @@index([taskId], map: "idx_time_entries_task")
  @@index([status], map: "idx_time_entries_status")
  @@map("time_entries")
}

// ─── Email Records ─────────────────────────────────────────

model EmailRecord {
  id                    String    @id @default(uuid()) @db.Uuid
  tenantId              String    @map("tenant_id") @db.Uuid
  gmailId               String    @unique @map("gmail_id") @db.VarChar(200)
  threadId              String?   @map("thread_id") @db.VarChar(200)
  from                  String    @db.VarChar(500)
  to                    String[]  @db.VarChar(500)
  cc                    String[]  @db.VarChar(500)
  subject               String    @db.VarChar(1000)
  snippet               String?   @db.Text
  receivedAt            DateTime  @map("received_at") @db.Timestamptz
  direction             String    @default("inbound") @db.VarChar(10)
  isProcessed           Boolean   @default(false) @map("is_processed")
  projectId             String?   @map("project_id") @db.Uuid
  clientId              String?   @map("client_id") @db.Uuid
  personId              String?   @map("person_id") @db.Uuid
  opportunityId         String?   @map("opportunity_id") @db.Uuid
  categorizationMethod  String?   @map("categorization_method") @db.VarChar(50)
  validationStatus      String    @default("por_confirmar") @map("validation_status") @db.VarChar(20)
  aiConfidence          Decimal?  @map("ai_confidence")
  interactionId         String?   @unique @map("interaction_id") @db.Uuid
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  project     Project?     @relation(fields: [projectId], references: [id])
  client      Client?      @relation("EmailClient", fields: [clientId], references: [id])
  person      Person?      @relation("EmailPerson", fields: [personId], references: [id])
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id])
  interaction Interaction? @relation(fields: [interactionId], references: [id])

  @@index([tenantId])
  @@index([isProcessed], map: "idx_email_records_processed")
  @@index([projectId], map: "idx_email_records_project")
  @@index([clientId], map: "idx_email_records_client")
  @@index([receivedAt(sort: Desc)], map: "idx_email_records_date")
  @@map("email_records")
}

// ─── Investment Maps ───────────────────────────────────────

model InvestmentMap {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  projectId         String    @unique @map("project_id") @db.Uuid
  totalBudget       Decimal   @map("total_budget") @db.Decimal(14, 2)
  fundingSource     String?   @map("funding_source") @db.VarChar(200)
  fundingPercentage Decimal?  @map("funding_percentage") @db.Decimal(5, 2)
  startDate         DateTime? @map("start_date") @db.Date
  endDate           DateTime? @map("end_date") @db.Date
  archivedAt        DateTime? @map("archived_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  project  Project           @relation(fields: [projectId], references: [id])
  rubrics  InvestmentRubric[]

  @@unique([tenantId, projectId])
  @@index([tenantId])
  @@map("investment_maps")
}

model InvestmentRubric {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  investmentMapId String    @map("investment_map_id") @db.Uuid
  name            String    @db.VarChar(300)
  budgetAllocated Decimal   @map("budget_allocated") @db.Decimal(14, 2)
  budgetExecuted  Decimal   @default(0) @map("budget_executed") @db.Decimal(14, 2)
  areaId          String?   @map("area_id") @db.Uuid
  sortOrder       Int       @default(0) @map("sort_order")
  archivedAt      DateTime? @map("archived_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  investmentMap InvestmentMap @relation(fields: [investmentMapId], references: [id], onDelete: Cascade)
  area          Area?         @relation("RubricArea", fields: [areaId], references: [id])

  @@index([tenantId])
  @@index([investmentMapId], map: "idx_investment_rubrics_map")
  @@map("investment_rubrics")
}

// ─── Email Campaigns ──────────────────────────────────────

model EmailCampaign {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  name            String    @db.VarChar(300)
  subject         String    @db.VarChar(500)
  htmlContent     String    @map("html_content") @db.Text
  status          String    @default("draft") @db.VarChar(20)
  audienceFilter  Json      @default("{}") @map("audience_filter")
  scheduledAt     DateTime? @map("scheduled_at") @db.Timestamptz
  sentAt          DateTime? @map("sent_at") @db.Timestamptz
  sentCount       Int       @default(0) @map("sent_count")
  openCount       Int       @default(0) @map("open_count")
  bounceCount     Int       @default(0) @map("bounce_count")
  templateId      String?   @map("template_id") @db.Uuid
  createdById     String?   @map("created_by") @db.Uuid
  archivedAt      DateTime? @map("archived_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant     Tenant             @relation(fields: [tenantId], references: [id])
  template   EmailTemplate?     @relation(fields: [templateId], references: [id])
  createdBy  Person?            @relation("CampaignCreator", fields: [createdById], references: [id])
  recipients CampaignRecipient[]

  @@index([tenantId])
  @@index([status], map: "idx_email_campaigns_status")
  @@map("email_campaigns")
}

model EmailTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(300)
  subject     String   @db.VarChar(500)
  htmlContent String   @map("html_content") @db.Text
  variables   Json     @default("[]")
  isSystem    Boolean  @default(false) @map("is_system")
  archivedAt  DateTime? @map("archived_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  campaigns EmailCampaign[]

  @@index([tenantId])
  @@map("email_templates")
}

model CampaignRecipient {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  campaignId String    @map("campaign_id") @db.Uuid
  personId   String?   @map("person_id") @db.Uuid
  email      String    @db.VarChar(500)
  status     String    @default("pending") @db.VarChar(20)
  sentAt     DateTime? @map("sent_at") @db.Timestamptz
  openedAt   DateTime? @map("opened_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  tenant   Tenant        @relation(fields: [tenantId], references: [id])
  campaign EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  person   Person?       @relation("CampaignRecipientPerson", fields: [personId], references: [id])

  @@index([tenantId])
  @@index([campaignId], map: "idx_campaign_recipients_campaign")
  @@index([campaignId, status], map: "idx_campaign_recipients_status")
  @@map("campaign_recipients")
}
